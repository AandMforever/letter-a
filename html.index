<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Letter A - A True Love Meter</title>

<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    text-align: center;
    background: linear-gradient(135deg, #7e22ce, #ec4899);
    color: white;
}

.container {
    padding: 60px 20px;
}

h1 {
    font-size: 3em;
    margin-bottom: 10px;
}

h2 {
    font-weight: normal;
    margin-bottom: 40px;
}

.meter-box {
    width: 80%;
    max-width: 400px;
    height: 35px;
    margin: 0 auto;
    background: rgba(255,255,255,0.3);
    border-radius: 50px;
    overflow: hidden;
}

.meter-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, #ff4da6, #ff99cc);
    transition: width 0.2s;
}

.percent {
    margin-top: 15px;
    font-size: 1.4em;
}

button {
    margin-top: 30px;
    padding: 12px 25px;
    font-size: 1.1em;
    border: none;
    border-radius: 40px;
    background: #ff4da6;
    color: white;
    cursor: pointer;
}

button:hover {
    transform: scale(1.05);
}

.result {
    margin-top: 40px;
    font-size: 1.6em;
    display: none;
}
</style>
</head>

<body>

<div class="container">
    <h1>Letter A 💕</h1>
    <h2>A True Love Meter</h2>

    <div class="meter-box">
        <div class="meter-fill" id="meter"></div>
    </div>

    <div class="percent" id="percentText">0%</div>

    <button onclick="startMeter()">Scan True Love 💖</button>

    <div class="result" id="resultText">
        💜 TRUE LOVE CONFIRMED 💜<br>
        Result: ∞%<br><br>
        No errors. Only us.
    </div>
</div>

<script>
let percent = 0;
let running = false;

function startMeter() {
    if (running) return;
    running = true;

    let meter = document.getElementById("meter");
    let text = document.getElementById("percentText");
    let result = document.getElementById("resultText");

    let interval = setInterval(function() {
        percent += Math.floor(Math.random() * 6) + 4;

        if (percent >= 100) {
            percent = 100;
            clearInterval(interval);

            setTimeout(function() {
                text.innerHTML = "∞%";
                meter.style.width = "100%";
                result.style.display = "block";
            }, 600);
        }

        meter.style.width = percent + "%";
        text.innerHTML = percent + "%";

    }, 200);
}
</script>

</body>
</html>
